-- APPLY THEME
-------------------------------------------------
local function applyTheme(name)
    local preset = ThemePresets[name]
    if not preset then return end
    currentThemeName = name
    UserSettings.Theme = name
    for k, v in pairs(preset) do Theme[k] = v end
    for _, entry in ipairs(ColorRegistry) do
        if entry.obj and entry.obj.Parent then
            entry.obj[entry.prop] = Theme[entry.role]
        end
    end
    if MainGradient then
        MainGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.Background:Lerp(Theme.AccentDark, 0.18)),
            ColorSequenceKeypoint.new(0.5, Theme.Background),
            ColorSequenceKeypoint.new(1, Theme.Background:Lerp(Color3.new(0,0,0), 0.3)),
        })
    end
    if TitleGradient then
        TitleGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.AccentDark),
            ColorSequenceKeypoint.new(1, Theme.Accent:Lerp(Theme.AccentDark, 0.3)),
        })
    end
    SaveSettings()
end

