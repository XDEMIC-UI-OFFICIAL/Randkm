-- SAVE / LOAD
-------------------------------------------------
local SAVE_NAME = "XDEMIC_UI_SAVE"

local function SaveSettings()
    local json = HttpService:JSONEncode(UserSettings)
    local save = PlayerGui:FindFirstChild(SAVE_NAME)
    if not save then
        save = Instance.new("StringValue")
        save.Name = SAVE_NAME
        save.Parent = PlayerGui
    end
    save.Value = json
end

local function LoadSettings()
    local save = PlayerGui:FindFirstChild(SAVE_NAME)
    if not save or save.Value == "" then return false end
    local success, data = pcall(function()
        return HttpService:JSONDecode(save.Value)
    end)
    if success and type(data) == "table" then
        for k, v in pairs(data) do
            if DEFAULT_SETTINGS[k] ~= nil then
                UserSettings[k] = v
            end
        end
        return true
    end
    return false
end

