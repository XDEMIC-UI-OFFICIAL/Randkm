local function registerText(obj, baseSize)
    TextRegistry[obj] = baseSize
    obj.TextSize = baseSize * Theme.TextScale
end

local function registerColor(obj, prop, role)
    table.insert(ColorRegistry, {obj = obj, prop = prop, role = role})
    obj[prop] = Theme[role]
    return obj
end

local function tween(obj, props, t, style)
    t = Theme.ReducedMotion and 0.01 or (t or 0.2)
    style = style or Enum.EasingStyle.Quad
    TweenService:Create(obj, TweenInfo.new(t, style, Enum.EasingDirection.Out), props):Play()
    return obj
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 12)
    c.Parent = parent
    return c
end

local function stroke(parent, role, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0
    s.Parent = parent
    registerColor(s, "Color", role or "Accent")
    table.insert(StrokeRegistry, {obj = s, base = thickness or 1})
    return s
end

