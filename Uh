local accessibilityAdded = false

function Library:AddAccessibilityTab()
    if accessibilityAdded then return end
    accessibilityAdded = true

    local AccTab = Library:CreateTab("Accessibility")

    for _, t in ipairs(tabs) do
        if t.Page == AccTab.Page then
            t.Button.LayoutOrder = 999999
            if #tabs > 1 then
                t.Page.Visible = false
                t.SetSelected(false)
            end
        end
    end

    AccTab:AddHeader("Appearance")
    AccTab:AddDropdown("Color Theme", Library:GetThemeNames(), function(selected)
        applyTheme(selected)
        UserSettings.Theme = selected
        SaveSettings()
    end)

    local uiScaleSlider = AccTab:AddSlider("UI Scale", 50, 150, UserSettings.UIScale, function(v)
        baseUIScale = v / 100
        UserSettings.UIScale = v
        recalcScale()
        SaveSettings()
    end)

    local textSizeSlider = AccTab:AddSlider("Text Size", 80, 150, UserSettings.TextSize, function(v)
        Theme.TextScale = v / 100
        UserSettings.TextSize = v
        for obj, base in pairs(TextRegistry) do
            if obj and obj.Parent then obj.TextSize = base * Theme.TextScale end
        end
        SaveSettings()
    end)

    local transparencySlider = AccTab:AddSlider("Window Transparency", 0, 90, UserSettings.Transparency, function(v)
        Theme.Transparency = v / 100
        UserSettings.Transparency = v
        if not Theme.HighContrast then Main.BackgroundTransparency = Theme.Transparency end
        SaveSettings()
    end)

    local highContrastToggle = AccTab:AddToggle("High Contrast Mode", UserSettings.HighContrast, function(state)
        Theme.HighContrast = state
        UserSettings.HighContrast = state
        if state then
            Main.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            Main.BackgroundTransparency = 0.1
        else
            Main.BackgroundColor3 = Theme.Background
            Main.BackgroundTransparency = Theme.Transparency
        end
        SaveSettings()
    end)

    AccTab:AddHeader("Comfort")
    local reducedMotionToggle = AccTab:AddToggle("Reduced Motion", UserSettings.ReducedMotion, function(state)
        Theme.ReducedMotion = state
        UserSettings.ReducedMotion = state
        SaveSettings()
    end)

    local dyslexiaToggle = AccTab:AddToggle("Dyslexia-Friendly Font", UserSettings.DyslexiaFont, function(state)
        UserSettings.DyslexiaFont = state
        for obj in pairs(TextRegistry) do
            if obj and obj.Parent then
                if state then
                    obj:SetAttribute("OrigFont", obj.Font.Name)
                    obj.Font = Enum.Font.Sans
                else
                    local orig = obj:GetAttribute("OrigFont")
                    obj.Font = (orig and Enum.Font[orig]) or Theme.FontRegular
                end
            end
        end
        SaveSettings()
    end)

    local colorblindToggle = AccTab:AddToggle("Colorblind Safe Palette", UserSettings.ColorblindSafe, function(state)
        UserSettings.ColorblindSafe = state
        if state then
            themeBeforeColorblind = currentThemeName
            applyTheme("ColorblindSafe")
        else
            applyTheme(themeBeforeColorblind)
        end
        SaveSettings()
    end)

    local reduceGlowToggle = AccTab:AddToggle("Reduce Glow / Outline Effects", UserSettings.ReduceGlow, function(state)
        UserSettings.ReduceGlow = state
        for _, e in ipairs(StrokeRegistry) do
            if e.obj and e.obj.Parent then
                e.obj.Thickness = state and 0 or e.base
            end
        end
        SaveSettings()
    end)

    AccTab:AddHeader("Interaction")
    local largerTargetsToggle = AccTab:AddToggle("Larger Click Targets", UserSettings.LargerTargets, function(state)
        largerTargetsBonus = state and 0.15 or 0
        UserSettings.LargerTargets = state
        recalcScale()
        SaveSettings()
    end)

    local soundsToggle = AccTab:AddToggle("Button Click Sounds", UserSettings.ClickSounds, function(state)
        soundsEnabled = state
        UserSettings.ClickSounds = state
        SaveSettings()
    end)

    local keybindToggle = AccTab:AddToggle("Enable Hotkey to Open/Close", UserSettings.KeybindEnabled, function(state)
        uiKeybindEnabled = state
        UserSettings.KeybindEnabled = state
        SaveSettings()
    end)

    AccTab:AddDropdown("Open/Close Keybind", {"RightControl", "RightShift", "Insert", "End", "F4", "Backslash"}, function(selected)
        currentKeybind = Enum.KeyCode[selected]
        UserSettings.OpenKeybind = selected
        SaveSettings()
    end)

    local autoCloseSlider = AccTab:AddSlider("Auto-Close After Inactivity (sec, 0 = off)", 0, 120, UserSettings.AutoClose, function(v)
        autoCloseSeconds = v
        UserSettings.AutoClose = v
        SaveSettings()
    end)

    AccTab:AddHeader("Bubble")
    local bubbleSizeSlider = AccTab:AddSlider("Bubble Size", 40, 90, UserSettings.BubbleSize, function(v)
        Bubble.Size = UDim2.new(0, v, 0, v)
        for _, c in ipairs(Bubble:GetChildren()) do
            if c:IsA("UICorner") then c.CornerRadius = UDim.new(0, v / 2) end
        end
        UserSettings.BubbleSize = v
        SaveSettings()
    end)

    local edgeSnapToggle = AccTab:AddToggle("Snap Bubble to Screen Edge", UserSettings.EdgeSnap, function(state)
        bubbleEdgeSnap = state
        UserSettings.EdgeSnap = state
        SaveSettings()
    end)

    AccTab:AddButton("Reset Bubble Position", function()
        Bubble.Position = UDim2.new(0, 20, 0.5, -UserSettings.BubbleSize / 2)
        playClick()
    end)

    AccTab:AddHeader("Data")
    AccTab:AddButton("Export Config to Clipboard", function()
        local json = HttpService:JSONEncode(UserSettings)
        local ok = pcall(function() setclipboard(json) end)
        if ok then
            Library:Notify("Config Exported", "Settings copied to your clipboard.", 3)
        else
            Library:Notify("Export Failed", "Your executor doesn't support setclipboard.", 3)
        end
    end)

    AccTab:AddHeader("Reset")
    AccTab:AddButton("Reset to Defaults", function()
        for k, v in pairs(DEFAULT_SETTINGS) do UserSettings[k] = v end
        applyTheme(UserSettings.Theme)
        uiScaleSlider:Set(UserSettings.UIScale)
        textSizeSlider:Set(UserSettings.TextSize)
        transparencySlider:Set(UserSettings.Transparency)
        highContrastToggle:Set(UserSettings.HighContrast)
        reducedMotionToggle:Set(UserSettings.ReducedMotion)
        dyslexiaToggle:Set(UserSettings.DyslexiaFont)
        colorblindToggle:Set(UserSettings.ColorblindSafe)
        reduceGlowToggle:Set(UserSettings.ReduceGlow)
        largerTargetsToggle:Set(UserSettings.LargerTargets)
        soundsToggle:Set(UserSettings.ClickSounds)
        keybindToggle:Set(UserSettings.KeybindEnabled)
