    -- ==================================================================
    -- NEW Rayfield‑compatible Color Picker (HSV)
    -- ==================================================================
    function Tab:AddColorPicker(text, defaultColor, callback)
        defaultColor = defaultColor or Color3.fromRGB(255, 255, 255)

        -- Convert Color3 to HSV (0-1)
        local function rgbToHsv(r, g, b)
            r, g, b = r/255, g/255, b/255
            local max, min = math.max(r, g, b), math.min(r, g, b)
            local h, s, v = 0, 0, max
            if max ~= min then
                local d = max - min
                s = d / max
                if max == r then
                    h = (g - b) / d
                    if g < b then h = h + 6 end
                elseif max == g then
                    h = (b - r) / d + 2
                else
                    h = (r - g) / d + 4
                end
                h = h / 6
            end
            return h, s, v
        end

        local function hsvToRgb(h, s, v)
            local r, g, b
            if s == 0 then
                r, g, b = v, v, v
            else
                local i = math.floor(h * 6)
                local f = h * 6 - i
                local p = v * (1 - s)
                local q = v * (1 - s * f)
                local t = v * (1 - s * (1 - f))
                i = i % 6
                if i == 0 then r, g, b = v, t, p
                elseif i == 1 then r, g, b = q, v, p
                elseif i == 2 then r, g, b = p, v, t
                elseif i == 3 then r, g, b = p, q, v
                elseif i == 4 then r, g, b = t, p, v
                else r, g, b = v, p, q end
            end
            return Color3.fromRGB(r*255, g*255, b*255)
        end

        local hue, sat, val = rgbToHsv(defaultColor.R*255, defaultColor.G*255, defaultColor.B*255)

        local Holder = Instance.new("Frame")
        Holder.Size = UDim2.new(1, 0, 0, 180)
