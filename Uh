local NotificationContainer = nil

function Library:Notify(titleOrTable, message, duration)
    local title, content, dur
    if type(titleOrTable) == "table" then
        title = titleOrTable.Title
        content = titleOrTable.Content
        dur = titleOrTable.Duration
    else
        title, content, dur = titleOrTable, message, duration
    end
    dur = dur or 3

    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 380, 0, 0)
    notif.AutomaticSize = Enum.AutomaticSize.Y
    notif.BackgroundColor3 = Theme.ElementBG
    notif.BackgroundTransparency = 1
    notif.LayoutOrder = os.clock() * 1000
    notif.Parent = NotificationContainer
    corner(notif, 16)
    local nStroke = stroke(notif, "Accent", 1, 0.25)

    local pad = Instance.new("UIPadding")
    pad.PaddingTop = UDim.new(0, 10)
    pad.PaddingBottom = UDim.new(0, 10)
    pad.PaddingLeft = UDim.new(0, 14)
    pad.PaddingRight = UDim.new(0, 14)
    pad.Parent = notif

    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, 0, 0, 20)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Font = Theme.Font
    titleLbl.TextColor3 = Theme.Accent
    titleLbl.TextTransparency = 1
    titleLbl.Text = title or ""
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = notif
    registerText(titleLbl, 15)

    local msgLbl = Instance.new("TextLabel")
    msgLbl.Size = UDim2.new(1, 0, 0, 0)
    msgLbl.AutomaticSize = Enum.AutomaticSize.Y
    msgLbl.Position = UDim2.new(0, 0, 0, 22)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Font = Theme.FontRegular
    msgLbl.TextColor3 = Theme.SubText
    msgLbl.TextTransparency = 1
    msgLbl.Text = content or ""
    msgLbl.TextXAlignment = Enum.TextXAlignment.Left
    msgLbl.TextWrapped = true
    msgLbl.Parent = notif
    registerText(msgLbl, 13)

    tween(notif, {BackgroundTransparency = 0.06}, 0.25)
    tween(titleLbl, {TextTransparency = 0}, 0.25)
    tween(msgLbl, {TextTransparency = 0}, 0.25)
    tween(nStroke, {Transparency = 0.25}, 0.25)

    task.delay(dur, function()
        if not notif.Parent then return end
        tween(notif, {BackgroundTransparency = 1}, 0.25)
        tween(titleLbl, {TextTransparency = 1}, 0.25)
        tween(msgLbl, {TextTransparency = 1}, 0.25)
        tween(nStroke, {Transparency = 1}, 0.25)
        task.delay(0.25, function()
            if notif then notif:Destroy() end
        end)
    end)
end

