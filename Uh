        })
        SatGrad.Parent = SatOverlay

        -- Overlay: value (transparent to black, vertical)
        local ValOverlay = Instance.new("Frame")
        ValOverlay.Size = UDim2.new(1, 0, 1, 0)
        ValOverlay.BackgroundColor3 = Color3.new(0,0,0)
        ValOverlay.BackgroundTransparency = 0
        ValOverlay.Parent = Square
        local ValGrad = Instance.new("UIGradient")
        ValGrad.Rotation = 90
        ValGrad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        })
        ValGrad.Parent = ValOverlay

        local SquareKnob = Instance.new("Frame")
        SquareKnob.Size = UDim2.new(0, 12, 0, 12)
        SquareKnob.Position = UDim2.new(sat, -6, 1 - val, -6)
        SquareKnob.BackgroundColor3 = Color3.new(1,1,1)
        SquareKnob.Parent = Square
        corner(SquareKnob, 6)
        stroke(SquareKnob, "Accent", 1.5, 0.4)

        -- Dragging logic for both
        local draggingHue = false
        local draggingSquare = false

        local function updateColor()
            local color = hsvToRgb(hue, sat, val)
            Preview.BackgroundColor3 = color
            Square.BackgroundColor3 = hsvToRgb(hue, 1, 1)
            if callback then callback(color) end
        end

        -- Hue drag
        HueKnob.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingHue = true
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingHue = false
                draggingSquare = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if draggingHue and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local rel = math.clamp((input.Position.X - HueTrack.AbsolutePosition.X) / HueTrack.AbsoluteSize.X, 0, 1)
                hue = rel
                HueKnob.Position = UDim2.new(rel, -8, 0.5, -8)
                updateColor()
            end
            if draggingSquare and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local pos = input.Position - Square.AbsolutePosition
                local s = math.clamp(pos.X / Square.AbsoluteSize.X, 0, 1)
                local v = 1 - math.clamp(pos.Y / Square.AbsoluteSize.Y, 0, 1)
                sat = s
                val = v
                SquareKnob.Position = UDim2.new(s, -6, 1 - v, -6)
                updateColor()
            end
        end)

        Square.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSquare = true
            end
        end)

        return {
            Get = function() return Preview.BackgroundColor3 end
        }
    end

    return Tab
end

