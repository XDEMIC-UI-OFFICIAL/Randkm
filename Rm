-- Load settings & finalize
-------------------------------------------------
local loaded = LoadSettings()
if loaded then
    applyTheme(UserSettings.Theme)
    Theme.Transparency = UserSettings.Transparency / 100
    Main.BackgroundTransparency = Theme.Transparency
    baseUIScale = UserSettings.UIScale / 100
    largerTargetsBonus = UserSettings.LargerTargets and 0.15 or 0
    recalcScale()
    Theme.TextScale = UserSettings.TextSize / 100
    for obj, base in pairs(TextRegistry) do
        if obj and obj.Parent then obj.TextSize = base * Theme.TextScale end
    end
    if UserSettings.HighContrast then
        Main.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        Main.BackgroundTransparency = 0.1
    end
    Theme.ReducedMotion = UserSettings.ReducedMotion
    soundsEnabled = UserSettings.ClickSounds
    uiKeybindEnabled = UserSettings.KeybindEnabled
    currentKeybind = Enum.KeyCode[UserSettings.OpenKeybind] or Enum.KeyCode.RightControl
    autoCloseSeconds = UserSettings.AutoClose
    bubbleEdgeSnap = UserSettings.EdgeSnap
    Bubble.Size = UDim2.new(0, UserSettings.BubbleSize, 0, UserSettings.BubbleSize)
    if UserSettings.ReduceGlow then
        for _, e in ipairs(StrokeRegistry) do
            if e.obj and e.obj.Parent then e.obj.Thickness = 0 end
        end
    end
end

