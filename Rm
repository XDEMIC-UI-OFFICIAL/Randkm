    game:GetService("Debris"):AddItem(snd, 2)
end

-------------------------------------------------
-- DRAGGABLE (clamp for centered windows)
-------------------------------------------------
local function makeDraggable(handle, target, opts)
    opts = opts or {}
    local dragging, dragStart, startPos, moved = false, nil, nil, false

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            moved = false
            dragStart = input.Position
            startPos = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if moved and opts.clamp then
                        local screenSize = target.Parent and target.Parent.AbsoluteSize or Vector2.new(1920, 1080)
                        local size = target.AbsoluteSize
                        local pos = target.AbsolutePosition
                        local anchor = target.AnchorPoint or Vector2.new(0, 0)
                        local clampedX = math.clamp(pos.X, 0, math.max(0, screenSize.X - size.X))
                        local clampedY = math.clamp(pos.Y, 0, math.max(0, screenSize.Y - size.Y))
                        local centerX = clampedX + size.X * anchor.X
                        local centerY = clampedY + size.Y * anchor.Y

                        if opts.edgeSnap and opts.edgeSnap() then
                            local mid = screenSize.X / 2
                            if pos.X + size.X / 2 < mid then
                                centerX = 8 + size.X * anchor.X
                            else
                                centerX = screenSize.X - size.X - 8 + size.X * anchor.X
                            end
                        end

                        tween(target, {Position = UDim2.new(0, centerX, 0, centerY)}, 0.15)
                    end
                    if opts.onDragEnd then opts.onDragEnd(moved) end
                end
            end)
        end
    end)

    handle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            if math.abs(delta.X) > 3 or math.abs(delta.Y) > 3 then moved = true end
            target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-------------------------------------------------
-- APPLY THEME
-------------------------------------------------
local function applyTheme(name)
    local preset = ThemePresets[name]
    if not preset then return end
    currentThemeName = name
    UserSettings.Theme = name
    for k, v in pairs(preset) do Theme[k] = v end
    for _, entry in ipairs(ColorRegistry) do
        if entry.obj and entry.obj.Parent then
            entry.obj[entry.prop] = Theme[entry.role]
        end
    end
    if MainGradient then
        MainGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.Background:Lerp(Theme.AccentDark, 0.12)),
            ColorSequenceKeypoint.new(1, Theme.Background:Lerp(Color3.new(0,0,0), 0.25)),
        })
    end
    if TitleGradient then
        TitleGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.AccentDark),
            ColorSequenceKeypoint.new(1, Theme.Accent:Lerp(Theme.AccentDark, 0.35)),
        })
    end
    SaveSettings()
end

