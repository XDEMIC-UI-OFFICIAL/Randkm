-------------------------------------------------
local isOpen = false
local lastInteraction = os.clock()
local currentKeybind = Enum.KeyCode[UserSettings.OpenKeybind] or Enum.KeyCode.RightControl

local function setCoreVisible(visible)
    pcall(function()
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat, visible)
        StarterGui:SetCore("TopbarEnabled", visible)
    end)
end

local function toggleMain()
    isOpen = not isOpen
    lastInteraction = os.clock()

    if isOpen then
        Main.Visible = true
        Main.Size = UDim2.new(0, 0, 0, 0)
        Main.BackgroundTransparency = 1

        tween(Main, {
            Size = UDim2.new(0, WindowSize.X, 0, WindowSize.Y),
            BackgroundTransparency = Theme.Transparency
        }, 0.32, Enum.EasingStyle.Back)

        if not UserSettings.ReduceGlow then
            MainStroke.Thickness = 1.5
            MainStroke.Transparency = 0
            tween(MainStroke, {Thickness = 6, Transparency = 0}, 0.16)
            task.delay(0.16, function()
                tween(MainStroke, {Thickness = 1.5, Transparency = 0.35}, 0.35)
            end)
        end

        setCoreVisible(false)
    else
        tween(Main, {
            Size = UDim2.new(0, 6, 0, 6),
            BackgroundTransparency = 1
        }, 0.2, Enum.EasingStyle.Quad)

        task.delay(0.2, function()
            if not isOpen then Main.Visible = false end
        end)
        setCoreVisible(true)
    end
end

Bubble.MouseButton1Click:Connect(function()
    if bubbleWasDragged then
        bubbleWasDragged = false
        return
    end
    toggleMain()
    playClick()
end)
CloseBtn.MouseButton1Click:Connect(function() toggleMain(); playClick() end)

local uiKeybindEnabled = UserSettings.KeybindEnabled
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    lastInteraction = os.clock()
    if uiKeybindEnabled and input.KeyCode == currentKeybind then
        toggleMain()
    end
end)

local autoCloseSeconds = UserSettings.AutoClose
task.spawn(function()
    while true do
        task.wait(1)
        if isOpen and autoCloseSeconds > 0 and (os.clock() - lastInteraction) >= autoCloseSeconds then
            toggleMain()
        end
    end
end)

