    function Tab:AddColorPicker(text, defaultColor, callback)
        defaultColor = defaultColor or Color3.fromRGB(255, 255, 255)

        local Holder = Instance.new("Frame")
        Holder.Size = UDim2.new(1, 0, 0, 110)
        Holder.LayoutOrder = nextOrder()
        Holder.Parent = Page
        registerColor(Holder, "BackgroundColor3", "ElementBG")
        corner(Holder, 10)

        local Label = Instance.new("TextLabel")
        Label.BackgroundTransparency = 1
        Label.Position = UDim2.new(0, 12, 0, 6)
        Label.Size = UDim2.new(1, -60, 0, 18)
        Label.Text = text
        Label.Font = Theme.FontRegular
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = Holder
        registerColor(Label, "TextColor3", "Text")
        registerText(Label, 13.5)

        local Swatch = Instance.new("Frame")
        Swatch.Size = UDim2.new(0, 26, 0, 26)
        Swatch.Position = UDim2.new(1, -38, 0, 4)
        Swatch.BackgroundColor3 = defaultColor
        Swatch.Parent = Holder
        corner(Swatch, 6)
        stroke(Swatch, "Accent", 1, 0.3)

        local r, g, b = defaultColor.R * 255, defaultColor.G * 255, defaultColor.B * 255
        local function makeChannel(label, yPos, initial, setFn)
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, -24, 0, 20)
            row.Position = UDim2.new(0, 12, 0, yPos)
            row.BackgroundTransparency = 1
            row.Parent = Holder

            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(0, 16, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = label
            lbl.Font = Theme.FontRegular
            lbl.Parent = row
            registerColor(lbl, "TextColor3", "SubText")
            registerText(lbl, 12)

            local track = Instance.new("Frame")
            track.Position = UDim2.new(0, 20, 0.5, -3)
            track.Size = UDim2.new(1, -20, 0, 6)
            track.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
            track.Parent = row
            corner(track, 3)

            local fill = Instance.new("Frame")
            fill.Size = UDim2.new(initial / 255, 0, 1, 0)
            fill.BackgroundColor3 = defaultColor
            fill.Parent = track
            corner(fill, 3)

            local knob = Instance.new("TextButton")
            knob.Size = UDim2.new(0, 12, 0, 12)
            knob.Position = UDim2.new(initial / 255, -6, 0.5, -6)
            knob.BackgroundColor3 = Color3.new(1, 1, 1)
            knob.Text = ""
            knob.Parent = track
            corner(knob, 6)

            local dragging = false
            knob.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    fill.Size = UDim2.new(rel, 0, 1, 0)
                    knob.Position = UDim2.new(rel, -6, 0.5, -6)
                    setFn(math.floor(rel * 255))
                end
            end)
            return fill
        end

        local rFill = makeChannel("R", 30, r, function(v) r = v end)
        local gFill = makeChannel("G", 55, g, function(v) g = v end)
        local bFill = makeChannel("B", 80, b, function(v) b = v end)

        RunService.Heartbeat:Connect(function()
            if Swatch.Parent then
                local c = Color3.fromRGB(math.clamp(r,0,255), math.clamp(g,0,255), math.clamp(b,0,255))
                if Swatch.BackgroundColor3 ~= c then
                    Swatch.BackgroundColor3 = c
                    rFill.BackgroundColor3 = c
                    gFill.BackgroundColor3 = c
                    bFill.BackgroundColor3 = c
                    if callback then callback(c) end
                end
            end
        end)

        return {
            Get = function() return Swatch.BackgroundColor3 end
        }
    end

