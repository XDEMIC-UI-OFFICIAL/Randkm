-- ★ RAYFIELD COMPATIBILITY SHIM ★
-------------------------------------------------
function Library:CreateWindow(settings)
    settings = settings or {}
    if settings.Name then Library:SetTitle(settings.Name) end

    local Window = {}

    function Window:CreateTab(name, _icon)
        local Tab = Library:CreateTab(name, _icon)

        function Tab:CreateSection(name) return Tab:AddHeader(name) end
        function Tab:CreateButton(cfg) return Tab:AddButton(cfg.Name, cfg.Callback) end
        function Tab:CreateToggle(cfg)
            local t = Tab:AddToggle(cfg.Name, cfg.CurrentValue, function(v)
                if cfg.Flag then Library.Flags[cfg.Flag] = v end
                if cfg.Callback then cfg.Callback(v) end
            end)
            if cfg.Flag then Library.Flags[cfg.Flag] = cfg.CurrentValue end
            return t
        end
        function Tab:CreateSlider(cfg)
            local range = cfg.Range or {0, 100}
            local s = Tab:AddSlider(cfg.Name, range[1], range[2], cfg.CurrentValue, function(v)
                if cfg.Flag then Library.Flags[cfg.Flag] = v end
                if cfg.Callback then cfg.Callback(v) end
            end)
            if cfg.Flag then Library.Flags[cfg.Flag] = cfg.CurrentValue end
            return s
        end
        function Tab:CreateDropdown(cfg)
            local d = Tab:AddDropdown(cfg.Name, cfg.Options or {}, function(selected)
                if cfg.Flag then Library.Flags[cfg.Flag] = selected end
                if cfg.Callback then cfg.Callback({selected}) end
            end)
            return d
        end
        function Tab:CreateInput(cfg)
            local i = Tab:AddTextbox(cfg.Name, cfg.PlaceholderText, cfg.CurrentValue, function(text, enter)
                if cfg.Flag then Library.Flags[cfg.Flag] = text end
                if cfg.Callback then cfg.Callback(text) end
            end)
            return i
        end
        function Tab:CreateLabel(text) return Tab:AddLabel(text) end
        function Tab:CreateParagraph(cfg) return Tab:AddParagraph(cfg) end
        function Tab:CreateColorPicker(cfg)
            return Tab:AddColorPicker(cfg.Name, cfg.Color, function(c)
                if cfg.Flag then Library.Flags[cfg.Flag] = c end
                if cfg.Callback then cfg.Callback(c) end
            end)
        end
        function Tab:CreateKeybind(cfg)
            return Tab:AddKeybind(cfg.Name, cfg.CurrentKeybind, function(key)
                if cfg.Flag then Library.Flags[cfg.Flag] = key end
                if cfg.Callback then cfg.Callback(key) end
            end)
        end

        return Tab
    end

    task.defer(function()
        if not accessibilityAdded then
            Library:AddAccessibilityTab()
        end
    end)

    return Window
end

return Library
